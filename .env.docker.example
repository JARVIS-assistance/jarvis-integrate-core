JARVIS_CORE_PORT=8000
JARVIS_CONTROLLER_PORT=8001
JARVIS_GATEWAY_PORT=8002
JARVIS_AI_WORKBENCH_PORT=8010

# jarvis-core
JARVIS_AUTH_SECRET=change-this-in-production
# Leave blank to use SQLite in the container volume.
JARVIS_CORE_DB_URL=
JARVIS_CORE_DB_USER=
JARVIS_CORE_DB_PASSWORD=
JARVIS_CORE_DB_HOST=
JARVIS_CORE_DB_PORT=5432
JARVIS_CORE_DB_NAME=postgres

# jarvis-gateway
JARVIS_GATEWAY_RATE_LIMIT=60
JARVIS_GATEWAY_RATE_WINDOW=60
